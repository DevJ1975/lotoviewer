# Copy to .env.local and fill in. .env* is gitignored.
#
# A fresh deploy that omits an entry below will silently lose the
# corresponding feature (Sentry reporting, push notifications, admin
# invites, support emails). Anything marked Required must be set;
# Optional vars degrade gracefully when absent.

# ── Supabase ────────────────────────────────────────────────────────────────

# Required. Get from Supabase Dashboard → Project Settings → API.
# Public — shipped to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for admin user-management routes (lib/supabaseAdmin).
# Server-only — DO NOT prefix with NEXT_PUBLIC_; must never reach the browser.
# Get from Supabase Dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# ── Sentry (error reporting + performance) ─────────────────────────────────

# Required for browser error reporting (instrumentation-client.ts).
# Without this, client-side exceptions are not captured.
NEXT_PUBLIC_SENTRY_DSN=

# Required for server + edge runtime error reporting
# (sentry.server.config.ts, sentry.edge.config.ts).
SENTRY_DSN=

# Optional. Sample rate (0.0–1.0) for performance traces. Defaults are
# applied in code if unset; explicit values are recommended in production.
SENTRY_TRACES_SAMPLE_RATE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=

# Optional. Sample rate (0.0–1.0) for Session Replay. Set the error rate
# to 1.0 in production so every error session is replayable; the always-on
# rate should stay low to control cost.
NEXT_PUBLIC_SENTRY_REPLAY_SAMPLE_RATE=
NEXT_PUBLIC_SENTRY_REPLAY_ERROR_SAMPLE_RATE=

# Required for source-map upload during `next build`. Without these, stack
# traces in Sentry stay minified. Get from Sentry → Settings → Auth Tokens.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Web Push (PWA notifications) ───────────────────────────────────────────

# Required for push notifications. Generate a VAPID key pair with
# `npx web-push generate-vapid-keys` and store both halves below.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Required by web-push as the contact subject (mailto: or https URL).
VAPID_SUBJECT=

# Required to authenticate internal calls to /api/push/dispatch and
# /api/cron/meter-bump-reminders from Supabase webhooks or non-Vercel
# schedulers. Generate a long random string.
INTERNAL_PUSH_SECRET=

# Optional. Vercel Cron sends `Authorization: Bearer <CRON_SECRET>` on
# scheduled invocations. /api/cron/meter-bump-reminders accepts either
# CRON_SECRET or INTERNAL_PUSH_SECRET via that header — set whichever
# fits your scheduler. With Vercel Cron only, set this and skip
# INTERNAL_PUSH_SECRET (or set both to the same value).
CRON_SECRET=

# ── Inspector access ───────────────────────────────────────────────────────

# Required to mint signed inspector URLs (/admin/inspector → /inspector).
# HMAC-SHA-256 secret; generate with `openssl rand -hex 32` or any tool
# that produces a long random string. Rotating this invalidates EVERY
# live inspector URL — that's the only "revoke" mechanism for the
# stateless token design (see lib/inspectorToken.ts).
INSPECTOR_TOKEN_SECRET=

# ── Email (Resend) ─────────────────────────────────────────────────────────

# Required for admin user-invite emails and support bug reports
# (lib/bugReport, app/api/admin/users, app/api/support/bug-report).
RESEND_API_KEY=

# Required as the verified-sender "from" address for invite emails.
# Must be on a domain you've verified in the Resend dashboard.
INVITE_FROM_EMAIL=

# Optional. Verified-sender "from" address for support bug-report emails.
# Falls back to Resend's onboarding@resend.dev sandbox sender if unset.
SUPPORT_FROM_EMAIL=

# Optional. Recipient address for support bug-report emails. Falls back
# to a hardcoded internal address if unset — set this for any deploy
# outside the original org.
SUPPORT_EMAIL=

# ── App URL ────────────────────────────────────────────────────────────────

# Required for invite emails to embed an absolute link to the app
# (used by app/api/admin/users). Should be the public URL with no trailing slash.
NEXT_PUBLIC_APP_URL=

{
  "name": "lotoviewer-monorepo",
  "version": "1.8.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace web run dev",
    "build": "npm --workspace web run build",
    "start": "npm --workspace web run start",
    "lint": "npm --workspace web run lint",
    "test": "npm --workspace web run test",
    "check:deeplinks": "node scripts/check-deeplink-placeholders.mjs",
    "check:wiki": "node scripts/check-wiki-sync.mjs",
    "check:wiki:staged": "node scripts/check-wiki-sync.mjs --staged",
    "wiki:touch": "node scripts/wiki-touch.mjs"
  },
  "dependencies": {
    "expo-router": "~6.0.23"
  }
}

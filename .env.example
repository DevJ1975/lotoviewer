# Copy to .env.local and fill in. .env* is gitignored.

# Public — shipped to the browser. Get from Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by the admin user-management API to create users.
# DO NOT prefix this with NEXT_PUBLIC_ — it must never reach the browser.
# Get from Supabase Dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=
